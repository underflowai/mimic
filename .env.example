# Director LLM — which provider powers the voice agent's conversational model
MIMIC_DIRECTOR_PROVIDER=openai   # openai | anthropic
MIMIC_OPENAI_DIRECTOR_MODEL=gpt-5-chat-latest
# MIMIC_ANTHROPIC_DIRECTOR_MODEL=claude-haiku-4-5

# OpenAI — used for director (if openai), background tasks, and web search
OPENAI_API_KEY=

# Anthropic — used for director (if anthropic)
# ANTHROPIC_API_KEY=

# Deepgram — speech-to-text (Flux v2)
DEEPGRAM_API_KEY=

# Cartesia — text-to-speech (Sonic)
CARTESIA_API_KEY=

# LiveKit — real-time audio transport
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# Redis — SDK tool bridge (server package only)
# REDIS_URL=redis://localhost:6379
