# OpenAI — used for director LLM, background tasks, and web search
OPENAI_API_KEY=

# Anthropic — only needed if using Anthropic as the director provider
# ANTHROPIC_API_KEY=

# Deepgram — speech-to-text (Flux v2)
DEEPGRAM_API_KEY=

# Cartesia — text-to-speech (Sonic)
CARTESIA_API_KEY=

# LiveKit — real-time audio transport
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# Redis — job queue for call processing (worker process)
REDIS_URL=redis://localhost:6379
# Set to 1 only when running a dedicated worker process.
# MIMIC_DISABLE_IN_PROCESS_WORKER=1

# Postgres — API keys, agents, calls, transcripts, and results
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mimic

# Call recording (optional) — S3-compatible storage for OGG recordings
# RECORDING_S3_BUCKET=
# RECORDING_S3_ACCESS_KEY=
# RECORDING_S3_SECRET=
# RECORDING_S3_REGION=us-east-1
# RECORDING_S3_ENDPOINT=
