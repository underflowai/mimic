{
	"name": "@mimic/engine",
	"version": "0.1.0",
	"type": "module",
	"description": "Real-time voice AI engine — turn management, ASR, TTS, backchannel, and tool orchestration.",
	"license": "MIT",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"import": "./build/index.js",
			"default": "./build/index.js"
		},
		"./livekit-transport": {
			"types": "./build/livekit-transport.d.ts",
			"import": "./build/livekit-transport.js",
			"default": "./build/livekit-transport.js"
		}
	},
	"imports": {
		"#engine/*": {
			"types": "./src/*",
			"source": "./src/*",
			"default": "./build/*"
		},
		"#test/*": "./test/*"
	},
	"files": ["build/"],
	"scripts": {
		"build": "tsc -b tsconfig.lib.json && node -e \"const{cpSync}=require('fs');cpSync('src/prompts','build/prompts',{recursive:true});cpSync('src/backchannel/audio','build/backchannel/audio',{recursive:true});try{cpSync('src/audio/silero_vad_v5.onnx','build/audio/silero_vad_v5.onnx')}catch{}\"",
		"prepare": "pnpm run build",
		"typecheck": "tsc -p tsconfig.lib.json --noEmit",
		"test": "NODE_OPTIONS='--conditions=source' tsx --test 'src/**/*.test.ts'"
	},
	"dependencies": {
		"openai": "^5.8.0",
		"onnxruntime-web": "^1.22.0",
		"p-queue": "^8.1.0",
		"pino": "^9.6.0",
		"remove-markdown": "^0.5.5",
		"xstate": "^5.19.4",
		"zod": "^3.24.4",
		"handlebars": "^4.7.8"
	},
	"peerDependencies": {
		"@livekit/rtc-node": ">=0.13.25 <0.14.0",
		"@sentry/node": ">=9.0.0"
	},
	"peerDependenciesMeta": {
		"@sentry/node": {
			"optional": true
		}
	},
	"devDependencies": {
		"@livekit/rtc-node": "^0.13.28",
		"@types/node": "^22.15.0",
		"pino-pretty": "^13.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3"
	}
}
