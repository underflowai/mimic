{
	"name": "@mimic/sdk",
	"version": "0.1.0",
	"type": "module",
	"description": "Make AI phone calls with a few lines of code. Tools run locally — no webhooks needed.",
	"license": "MIT",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"import": "./build/index.js",
			"default": "./build/index.js"
		}
	},
	"files": [
		"build/"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsc -b tsconfig.lib.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "tsx --test 'src/**/*.test.ts'"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"zod": "^3.25.0"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^3.25.0"
	}
}
