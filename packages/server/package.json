{
	"name": "@mimic/server",
	"version": "0.1.0",
	"type": "module",
	"description": "Voice API server — SIP dialing, call lifecycle, goal compiler, result extraction.",
	"license": "MIT",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./src/index.ts",
				"production": "./build/index.js",
				"default": "./src/index.ts"
			}
		}
	},
	"files": [
		"build/",
		"README.md"
	],
	"scripts": {
		"start": "tsx src/serve.ts",
		"dev": "tsx watch src/serve.ts",
		"build": "tsc -b tsconfig.lib.json",
		"typecheck": "tsc -b --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.2",
		"@hono/node-ws": "^1.3.1",
		"@mimic/engine": "workspace:*",
		"@mimic/transport-livekit": "workspace:*",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.18",
		"livekit-server-sdk": "^2.15.3",
		"openai": "^5.8.0",
		"postgres": "^3.4.9",
		"zod": "^3.24.4"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.0",
		"typescript": "^5.8.3"
	}
}
