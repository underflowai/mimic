{
	"compilerOptions": {
		"target": "ES2024",
		"lib": ["ES2024", "DOM"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"disableReferencedProjectLoad": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "build",
		"rootDir": "src",
		"composite": false
	},
	"include": ["src"]
}
