{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"references": [
		{ "path": "packages/engine" },
		{ "path": "packages/transport-livekit" },
		{ "path": "packages/sdk" },
		{ "path": "packages/server" }
	],
	"files": []
}
